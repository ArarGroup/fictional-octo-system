# PostHog (proyecto → Project Settings → Project API Key)
# Sin esta variable el SDK no se inicializa y la app funciona igual en local.
VITE_POSTHOG_KEY=

# Opcional: host de la API (EU: https://eu.i.posthog.com ; US por defecto en código)
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Opcional: logs verbose en consola (true / omitir)
# VITE_POSTHOG_DEBUG=true

# Opcional: versión mostrada en propiedades de eventos (default 0.1.0)
# VITE_APP_VERSION=0.1.0
